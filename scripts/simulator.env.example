# =============================================================================
# Simulator 服务配置 — 换模型/换地址时只改本文件（复制为 simulator.env）
#
#   cp simulator.env.example simulator.env
#   nano simulator.env
#
# smoke_train_with_services.sh / train_with_services.sh 会自动读取 simulator.env
# simulator.env 含内网地址或 key，不要 push 到 GitHub
# =============================================================================

SIMULATOR_BASE_URL=http://<32B-vllm-内网地址>/v1
SIMULATOR_API_KEY=EMPTY
EXTERNAL_MODEL=qwen3-32b
